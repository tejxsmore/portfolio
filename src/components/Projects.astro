---
import { project } from "../../public/projects";
import { FaGithub } from "react-icons/fa";
import { FaExternalLinkAlt } from "react-icons/fa";
---

<div id="projects" class="md:p-16 md:px-10 p-8 bg-dark text-light">
  <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-center pb-16">
    Projects
  </h2>
  <div class="flex justify-center items-center">
    <div class="md:w-[1160px] md:flex md:flex-wrap justify-evenly">
      {
        project.map((item) => (
          <div class="md:p-4 py-4">
            <div class="text-light border-2 border-light border-dashed">
              <a href={item.link} target="_blank">
                <img
                  id="img"
                  src={item.img}
                  alt={item.title}
                  class="p-4 md:w-[350px]"
                />
              </a>
              <h3 class="text-2xl font-bold p-4 flex items-center">
                {item.title}
                <a href={item.git} target="_blank" class="mx-4 text-lg">
                  <FaGithub />
                </a>
                <a href={item.link} target="_blank" class="text-sm">
                  <FaExternalLinkAlt />
                </a>
              </h3>
              <h4 class="p-4 md:w-[350px] w-full">{item.description}</h4>
              <h5 class="flex flex-row p-4">
                {item.tech.map((tech) => (
                  <p class="bg-gradient-to-br from-orange to-pink text-light px-4 py-1 rounded-full mr-4">
                    {tech}
                  </p>
                ))}
              </h5>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>
