---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <nav
    class="flex justify-between bg-gradient-to-r from-purple-400 to-sky-200 p-2 h-16 w-full fixed"
  >
    <div class="text-xl w-20">
      <a href="/">
        <img src="/images/logo.png" alt="logo" class="object-contain" />
      </a>
    </div>
    <div class="flex">
      <a href="#about" class="p-3 text-md">01. About</a>
      <!-- <a href="#experience" class="p-3 text-md">02. Experience</a> -->
      <a href="#projects" class="p-3 text-md">02. Projects</a>
      <a href="#contact" class="p-3 text-md">03. Contact</a>

      <a
        href="/MyResume.pdf"
        download="MyResume.pdf"
        class="text-md px-4 m-1 pt-1.5 ml-2 text-center text-md rounded-md border-2 border-black hover:bg-yellow-300"
        >Resume</a
      >
    </div>
  </nav>
</Layout>
