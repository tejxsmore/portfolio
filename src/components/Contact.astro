---
import Layout from "../layouts/Layout.astro";
const year = new Date().getFullYear();
---

<Layout>
  <div
    id="contact"
    class="flex bg-gradient-to-r from-purple-400 to-sky-200 justify-center items-center"
  >
    <div class="max-w-4xl mt-32 mb-16">
      <div class="text-center p-6">
        <h1 class="text-5xl font-extrabold">03. Get in Touch</h1>
      </div>
      <div class="text-center p-6">
        <p class="text-xl items-center">
          Although I’m not currently looking for any new opportunities, my inbox
          is always open. Whether you have a question or just want to say hi,
          I’ll try my best to get back to you!
        </p>
      </div>
      <div class="text-center p-12">
        <a
          href="mailto:tejasmore1104@gmail.com"
          class="m-6 p-5 border-black border-2 rounded-md hover:bg-yellow-300"
          >Say Hello !</a
        >
      </div>
      <div class="text-center pt-40">
        <p>Designed & Built by Tejas More ©️ {year}</p>
      </div>
    </div>
  </div>
</Layout>
