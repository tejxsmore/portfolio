---
import { FaLinkedinIn } from "react-icons/fa";
import { FaGithub } from "react-icons/fa";
import { FaInstagram } from "react-icons/fa";
import { FaTelegramPlane } from "react-icons/fa";
import { FaXTwitter } from "react-icons/fa6";
---

<div
  id="contact"
  class="pt-4 pb-8 px-8 bg-dark flex justify-center items-center"
>
  <div class="max-w-xl flex gap-x-5">
    <a
      href="https://linkedin.com/in/tejxsmore"
      target="_blank"
      class="bg-light text-dark p-3 text-xl rounded-full"><FaLinkedinIn /></a
    >
    <a
      href="https://github.com/tejxsmore"
      target="_blank"
      class="bg-light text-dark p-3 text-xl rounded-full"><FaGithub /></a
    ><a
      href="https://twitter.com/tejxsmore"
      target="_blank"
      class="bg-light text-dark p-3 text-xl rounded-full"><FaXTwitter /></a
    >
    <a
      href="https://t.me/tejxsmore"
      target="_blank"
      class="bg-light text-dark p-3 text-xl rounded-full"
      ><FaTelegramPlane />
    </a>
  </div>
</div>
